rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /identify_temp/{uid}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /plant_photos/{uid}/{plantId}/{photoId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /profile_photos/{fileName} {
      allow read, write: if request.auth != null && fileName == request.auth.uid + '.jpg';
    }
  }
}

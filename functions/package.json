{
  "name": "functions",
  "description": "Thicket API-key proxy + shared cache for PlantNet/Perenual/OpenWeatherMap",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions,firestore",
    "test": "npm run build && mocha lib/**/*.test.js --timeout 10000",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^7.2.5"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/mocha": "^10.0.9",
    "@types/node": "^22.20.0",
    "@types/sinon": "^22.0.0",
    "firebase-functions-test": "^3.5.0",
    "mocha": "^10.7.3",
    "sinon": "^22.0.0",
    "typescript": "^5.6.3"
  },
  "private": true
}
